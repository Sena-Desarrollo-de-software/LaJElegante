# .env.example - Copia este archivo como .env y completa los valores para desarrollar en local

# Django settings
DJANGO_SECRET_KEY=your-secret-key-here-change-this-in-production #en tu ambiente virtual ejecuta "python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"" para generar una
DJANGO_DEBUG=True 

# Database - Elige una opción:

# Opción 1: MySQL (producción/desarrollo)
DATABASE_URL=mysql://usuario:contraseña@localhost:3306/nombre_bd

# Opción 2: SQLite (desarrollo local simple)
# DATABASE_URL=sqlite:///db.sqlite3

# Opción 3: PostgreSQL
# DATABASE_URL=postgres://usuario:contraseña@localhost:5432/nombre_bd

# Opcional: Configuraciones adicionales
ALLOWED_HOSTS=localhost,127.0.0.1

# Configuración String SQL
# DATABASE_URL=mysql://usuario:pass@localhost:3307/mi_bd